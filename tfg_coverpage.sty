\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tfg_coverpage}[2026/05/22 v2.0.0 Portada TFG UC3M]

% =====================================================================
%  PORTADA
%  ---------------------------------------------------------------------
%  Proporciona \makecover, que construye la portada con el estilo oficial
%  a partir de las variables definidas en tfg_vars.tex. El color azulUC3M
%  se define en tfg_uc3m.sty, que carga este paquete.
% =====================================================================

\RequirePackage{graphicx}
\RequirePackage{svg}                % Logotipos vectoriales
\RequirePackage{float}             % Posicionamiento de flotantes con [H]
\RequirePackage{ifthen}

% ---------------------------------------------------------------------
%  Aviso de licencia que se imprime al pie de la portada.
%  Lo gobierna \licenseType en tfg_vars.tex (valores: cc / reserved).
%  Puedes añadir más tipos de licencia siguiendo el mismo patrón.
% ---------------------------------------------------------------------
\newcommand{\license}[1]{%
  \ifthenelse{\equal{#1}{cc}}{%
    % Creative Commons (opción recomendada).
    \includesvg[width=4.2cm]{images/coverpage/creativecommons_by-nc-nd.eu.svg}\\
    Esta obra se encuentra sujeta a la licencia Creative Commons
    \textbf{Reconocimiento - No Comercial - Sin Obra Derivada}.%
  }{}%
  \ifthenelse{\equal{#1}{reserved}}{%
    Todos los derechos reservados.%
  }{}%
}

% ---------------------------------------------------------------------
%  \makecover - construye la portada.
% ---------------------------------------------------------------------
\newcommand{\makecover}{%
\begin{titlepage}
  \begin{sffamily}
  \color{azulUC3M}
  \begin{center}
    % Logotipo de la universidad
    \begin{figure}[H]
      \makebox[\textwidth][c]{\includesvg[width=16cm]{images/coverpage/UC3M_logo.svg}}
    \end{figure}
    \vspace{2.5cm}
    \begin{Large}
      \degree \\
      Curso académico \academicYear \\
      \vspace{2cm}
      \textsl{\thesisType}

      \bigskip
    \end{Large}
    {\Huge \thesisTitle}\\
    \vspace*{0.5cm}
    \rule{10.5cm}{0.1mm}\\
    \vspace*{0.9cm}
    {\LARGE \thesisAuthor}\\
    \vspace*{1cm}
    \begin{Large}
      Tutor/a\\
      \thesisAdvisor \\
      \placeAndDate \\
    \end{Large}
  \end{center}
  \vfill
  \color{black}
  \license{\licenseType}
  \end{sffamily}
\end{titlepage}
}

\endinput
