\counterwithout{footnote}{chapter}

% ---------------------------------------------------------------------
%  DATOS DEL USUARIO (título, autor, tutor, licencia, etc.)
%  Los carga tfg_main.tex antes de \documentclass (para poder leer ahí el
%  interruptor de PDF/A); aquí los valores ya están disponibles.
% ---------------------------------------------------------------------

% ---------------------------------------------------------------------
%  ENLACES Y METADATOS DEL PDF
%  csquotes y hyperref deben cargarse antes que biblatex (ver \custombib).
%  Los metadatos del PDF se toman automáticamente de tfg_vars.tex.
% ---------------------------------------------------------------------
\RequirePackage{csquotes}
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=black,                  % Enlaces internos (índice, refs.) en negro
  citecolor=black,                  % Citas en negro
  urlcolor=blue,                    % Enlaces externos (URLs) en azul
  pdftitle={\thesisTitle},
  pdfauthor={\thesisAuthor},
  pdfsubject={\thesisType{} -- \degree},
  pdfkeywords={\thesisType; \university; \keywordsEn; \keywordsEs},
  pdflang={es-ES},
  pdfcreator={LuaLaTeX - plantilla TFG UC3M - \templateRepo},
}

% En modo PDF/A el driver de pdfmanagement desactiva el color de los enlaces y
% quedan invisibles. Reactivamos los enlaces en color (azul estándar de PDF)
% solo en modo PDF/A; la compilación normal mantiene los colores de arriba. Se
% hace al final de \begin{document} para tener la última palabra sobre el driver.
\ifdefstring{\pdfaOutput}{true}{%
  \AddToHook{begindocument/end}{\hypersetup{colorlinks=true,linkcolor=linkColor,citecolor=linkColor,urlcolor=linkColor}}%
}{}

% Registramos los metadatos de la plantilla como propiedades PERSONALIZADAS; se
% ven en la pestaña "Custom" de Adobe con su valor COMPLETO (el campo Creator
% estándar lo recortan algunos visores). Las claves Info personalizadas son
% válidas en PDF/A (cf. el PTEX.Fullbanner de LuaTeX). Los valores se codifican
% con \pdfstringdef para que los acentos se guarden bien; PDF/A usa la API de
% pdfmanagement y la compilación normal el primitivo de LuaTeX.
\pdfstringdef\tfgMetaURL{\templateRepo}
\pdfstringdef\tfgMetaAuthor{\templateAuthor}
\pdfstringdef\tfgMetaContributors{\templateContributors}
\pdfstringdef\tfgMetaVersion{\templateVersion}
\pdfstringdef\tfgMetaDate{\templateDate}
\pdfstringdef\tfgMetaComments{\templateComments}
% El ayudante \tfgaddinfo escribe cada clave en el diccionario /Info con el
% backend adecuado al modo: pdfmanagement (PDF/A) si está disponible, o el
% primitivo de LuaTeX en caso contrario. Se define dentro de un bloque expl3
% limpio: el código expl3 NO debe ir dentro de una rama de \ifdefstring (la
% rama se tokeniza antes y romperían los nombres \cs_... / \pdfmanagement_...).
\ExplSyntaxOn
\cs_if_exist:NTF \pdfmanagement_add:nnn
  { \cs_generate_variant:Nn \pdfmanagement_add:nnn { nnx } }
  { }
\newcommand \tfgaddinfo [2]
  {
    \cs_if_exist:NTF \pdfmanagement_add:nnn
      { \pdfmanagement_add:nnx {Info} {#1} {(#2)} }
      { \pdfextension info {/#1 (#2)} }
  }
\ExplSyntaxOff
\tfgaddinfo{Template.URL}{\tfgMetaURL}
\tfgaddinfo{Template.Author}{\tfgMetaAuthor}
\tfgaddinfo{Template.Contributors}{\tfgMetaContributors}
\tfgaddinfo{Template.Version}{\tfgMetaVersion}
\tfgaddinfo{Template.Date}{\tfgMetaDate}
\tfgaddinfo{Template.Comments}{\tfgMetaComments}

% Selector del estilo de bibliografía, según \bibStyle en tfg_vars.tex.
% Puedes añadir más estilos siguiendo el mismo patrón.
\newcommand{\custombib}[1]{%
  \ifthenelse{\equal{#1}{apa}}{%
    % Estilo de bibliografía APA
    \usepackage[style=apa,backend=biber,natbib=true,hyperref=true,uniquelist=false,sortcites]{biblatex}%
    % Hacemos que \cite{...} se comporte como \parencite{...} para que las
    % citas en APA queden completamente entre paréntesis.
    \AtBeginDocument{%
      \DeclareCiteCommand{\cite}[\mkbibparens]%
        {\usebibmacro{prenote}}%
        {\usebibmacro{citeindex}\usebibmacro{cite}}%
        {\multicitedelim}%
        {\usebibmacro{postnote}}%
    }%
  }{}%
  \ifthenelse{\equal{#1}{ieee}}{%
    % Estilo de bibliografía IEEE
    \usepackage[style=ieee,backend=biber,natbib=true,hyperref=true,uniquelist=false,sortcites]{biblatex}%
  }{}%
}

