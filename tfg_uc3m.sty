\RequirePackage{multirow}           % Combinar celdas en varias filas
\RequirePackage{array}              % Tipos de columna extendidos
\RequirePackage{tabularx}           % Tablas de ancho fijo con celdas que ajustan línea
\RequirePackage{float}              % Posicionamiento exacto de flotantes con [H]
\RequirePackage{caption}            % Personalizar rótulos de figuras/tablas
\RequirePackage{subcaption}         % Subfiguras y subtablas
