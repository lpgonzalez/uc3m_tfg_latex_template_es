% =====================================================================
%  PAQUETE DE ESTILO PARA EL TRABAJO DE FIN DE GRADO (TFG) DE LA UC3M
%  ---------------------------------------------------------------------
%  Este paquete centraliza todos los paquetes, las reglas de maquetación
%  y la configuración, de modo que tfg_main.tex quede mínimo. Pon tus
%  datos en tfg_vars.tex y escribe tu contenido en chapters/ y others/.
%
%  COMPILADOR: LuaLaTeX (usa fontspec, microtype, emoji, svg...).
%  No compiles con pdfLaTeX.
% =====================================================================

% =====================================================================
%  CRÉDITOS Y AGRADECIMIENTOS
%  ---------------------------------------------------------------------
%  Plantilla basada en la plantilla oficial de TFG de la Universidad
%  Carlos III de Madrid, con influencias de otras plantillas, fragmentos
%  de código LaTeX de dominio público, desarrollos propios, y sugerencias
%  y mejoras aportadas por antiguos alumnos, además de diversas
%  optimizaciones.
%
%  A todas las alumnas y alumnos —pasados, presentes y futuros— que
%  confiaron, confían y confiarán en mí como tutor de TFG/TFM, y que me
%  inspiraron para rescatar, refactorizar y mejorar esta plantilla hasta
%  su estado actual, con el fin de facilitarles el desarrollo de su
%  trabajo de fin de etapa. Gracias también a la comunidad de LaTeX por
%  su extenso soporte, a las herramientas y plataformas que hacen posible
%  la edición colaborativa de LaTeX, y a quienes crearon LaTeX.
% =====================================================================

% ---------------------------------------------------------------------
%  IDIOMAS (babel)
%  El idioma principal es el declarado en ÚLTIMO lugar (español aquí);
%  también se carga el inglés para poder componer el abstract.
% ---------------------------------------------------------------------
\RequirePackage[english,spanish]{babel}
% Usar "Tabla" / "Índice de tablas" en lugar de los valores por defecto
% de babel-spanish ("Cuadro" / "Índice de cuadros").
\addto\captionsspanish{%
  \renewcommand{\tablename}{Tabla}%
  \renewcommand{\listtablename}{Índice de tablas}%
}

% ---------------------------------------------------------------------
%  TIPOGRAFÍA (fontspec - requiere LuaLaTeX/XeLaTeX)
%  TeX Gyre Heros es una fuente libre compatible con Helvetica/Arial,
%  incluida en TeX Live y en Overleaf, por lo que no hay que subir
%  ningún fichero de fuente. Para usar una serif tipo Times, comenta
%  las líneas de Heros y emplea "TeX Gyre Termes".
% ---------------------------------------------------------------------
\RequirePackage{fontspec}
\setmainfont{TeX Gyre Heros}        % Texto principal (similar a Arial)
\setsansfont{TeX Gyre Heros}        % Familia sans-serif
\setmonofont{TeX Gyre Cursor}       % Familia monoespaciada (para código)
\RequirePackage{microtype}          % Mejoras microtipográficas sutiles
\RequirePackage{emoji}              % Emojis a color (solo LuaLaTeX)
% Preferimos OpenMoji (fuente de color vectorial COLR) frente a Noto Color
% Emoji (de mapa de bits), para que los emojis salgan vectoriales y no raster.
% El fichero debe estar junto a tfg_main.tex (el \setemojifont del paquete
% emoji no admite Path), así que súbelo a la RAÍZ del proyecto en Overleaf. Si
% está, se usa; si no, la plantilla recurre a Noto. Build COLRv0 (glyf) de
% OpenMoji; novedades en https://openmoji.org.
\IfFileExists{OpenMoji-color-glyf_colr_0.ttf}{%
  \setemojifont{OpenMoji-color-glyf_colr_0.ttf}%
}{}

% ---------------------------------------------------------------------
%  GEOMETRÍA (normas UC3M: 2,5 cm sup./inf. y 3 cm izq./dcha.)
% ---------------------------------------------------------------------
\RequirePackage[a4paper,vmargin=2.5cm,hmargin=3cm]{geometry}

% ---------------------------------------------------------------------
%  INTERLINEADO (normas UC3M: 1,15) y separación entre párrafos
% ---------------------------------------------------------------------
\renewcommand{\baselinestretch}{1.15}
\setlength{\parskip}{1.5ex}

% ---------------------------------------------------------------------
%  PAQUETES DE PROPÓSITO GENERAL
% ---------------------------------------------------------------------
