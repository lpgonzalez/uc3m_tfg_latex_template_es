% ---------------------------------------------------------------------
%  ENCABEZADOS Y PIES DE PÁGINA (fancyhdr)
%  'tfgbody' es el estilo del cuerpo: marca de capítulo a la izquierda
%  en páginas pares, marca de sección a la derecha en páginas impares y
%  número de página centrado en el pie. 'plain' (inicio de capítulo y
%  páginas preliminares) muestra solo el número de página centrado.
% ---------------------------------------------------------------------
\RequirePackage{fancyhdr}
\setlength{\headheight}{16pt}   % >= 15.34pt, como exige fancyhdr
\renewcommand{\chaptermark}[1]{\markboth{\headertitlefont\thechapter\quad#1}{}}
\renewcommand{\sectionmark}[1]{\markright{\headertitlefont\thesection\quad#1}}
\fancypagestyle{tfgbody}{%
  \fancyhf{}
  \fancyhead[LE]{\leftmark}
  \fancyhead[RO]{\rightmark}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

% ---------------------------------------------------------------------
%  PÁGINA(S) APAISADA(S) FÍSICA(S)  (entorno tfglandscape)
%  ---------------------------------------------------------------------
%  Una o varias páginas realmente apaisadas (A4 horizontal): cambia el tamaño
%  FÍSICO de la hoja con \pagewidth/\pageheight (primitivas de LuaTeX), por lo
%  que se ve apaisada en cualquier visor y también en PDF/A (a diferencia del
%  /Rotate de pdflscape, que el backend de PDF/A no aplica). Conserva el
%  encabezado y el pie del cuerpo (tfgbody) y vale para tablas, figuras o texto.
%  Uso:
%      \begin{tfglandscape}
%        ...contenido ancho...
%      \end{tfglandscape}
%  Nota técnica: \textheight fija la altura de caja y, con ella, la posición del
%  pie; debe valer lo apaisado ANTES del \clearpage que inicia la hoja y volver a
%  lo vertical antes del \clearpage que la cierra (si no, la página siguiente
%  hereda la altura corta y su número sale más arriba). El tamaño físico se lee al
%  expulsar la página. Tras cambiar \textwidth hay que avisar a fancyhdr con
%  \headwidth para que el encabezado/pie ocupen todo el ancho. Ajusta los
%  márgenes (40 mm laterales, 50 mm verticales) a tu gusto.
\newlength{\tfg@saveTextheight}
\newenvironment{tfglandscape}{%
  \setlength{\tfg@saveTextheight}{\textheight}%       recuerda la altura vertical
  \setlength{\textheight}{\dimexpr\paperwidth-50mm\relax}% altura de caja apaisada
  \clearpage                                          % inicia la hoja apaisada con esa altura
  \pagewidth=\paperheight \pageheight=\paperwidth%    tamaño físico A4 horizontal
  \setlength{\textwidth}{\dimexpr\paperheight-40mm\relax}% márgenes laterales ~2 cm
  \setlength{\hsize}{\textwidth}\setlength{\linewidth}{\textwidth}\setlength{\columnwidth}{\textwidth}%
  \setlength{\oddsidemargin}{\dimexpr2cm-1in\relax}\setlength{\evensidemargin}{\oddsidemargin}%
  \setlength{\topmargin}{\dimexpr1.5cm-1in\relax}%
  \setlength{\footskip}{1cm}%
  \ifcsundef{headwidth}{}{\setlength{\headwidth}{\textwidth}}% encabezado/pie a todo el ancho
  \pagestyle{tfgbody}%
}{%
  \setlength{\textheight}{\tfg@saveTextheight}%       restaura la altura vertical
  \clearpage                                          % expulsa la apaisada; la siguiente vuelve a vertical
}

