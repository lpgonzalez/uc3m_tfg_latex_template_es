\graphicspath{{images/}}            % Carpeta por defecto de imágenes
\RequirePackage{svg}                % Gráficos vectoriales SVG (necesita Inkscape)
\RequirePackage{amsmath,amssymb,amsfonts}  % Matemáticas
\RequirePackage{eurosym}            % Símbolo del euro: \euro{}
\RequirePackage{relsize}            % Tamaños relativos: \smaller, \larger
\RequirePackage{lipsum}             % Texto de relleno "Lorem ipsum" (demo)
\RequirePackage{ifthen}             % \ifthenelse, usado por los selectores
\RequirePackage{tikz}               % Dibujo vectorial (usado por \tfgcheckmark)

% Pequeña marca de verificación, útil en tablas comparativas.
\newcommand{\tfgcheckmark}{\tikz\fill[scale=0.4](0,.35)--(.25,0)--(1,.7)--(.25,.15)--cycle;}

% ---------------------------------------------------------------------
%  PALETA DE COLORES (única fuente de verdad)
% ---------------------------------------------------------------------
\RequirePackage[table,svgnames]{xcolor}
% Los valores de color provienen de la sección COLORES de tfg_vars.tex.
\definecolor{azulUC3M}{RGB}{\colorBrand}
\definecolor{highlightYellow}{HTML}{\colorHighlight}
\definecolor{linkColor}{HTML}{\colorLink}
\definecolor{codeBackground}{gray}{\colorCodeBg}
\definecolor{codeComment}{gray}{\colorCodeComment}
\definecolor{codeNumbers}{gray}{\colorCodeNumbers}
\definecolor{codeKeyword}{HTML}{\colorCodeKeyword}
\definecolor{codeString}{HTML}{\colorCodeString}

% ---------------------------------------------------------------------
%  LISTADOS DE CÓDIGO FUENTE
%  Se aplica un único esquema de color a todos los listados. Para obtener
%  el resaltado correcto, basta con indicar el lenguaje en cada bloque:
%      \begin{lstlisting}[language=Python] ... \end{lstlisting}
%  listings ya conoce ~100 lenguajes (Python, C, C++, Java, HTML, SQL,
%  bash, Matlab, PHP, R, XML...). JavaScript se añade abajo (no viene de
%  fábrica). Para un lenguaje que listings no conozca, usa \lstdefinelanguage.
% ---------------------------------------------------------------------
\RequirePackage{listings}

% listings no trae JavaScript de fábrica: lo definimos de forma mínima.
\lstdefinelanguage{JavaScript}{%
  morekeywords={async,await,break,case,catch,class,const,continue,debugger,%
    default,delete,do,else,export,extends,finally,for,function,if,import,in,%
    instanceof,let,new,of,return,super,switch,this,throw,try,typeof,var,void,%
    while,with,yield,true,false,null,undefined},
  sensitive=true,
  morecomment=[l]{//},
  morecomment=[s]{/*}{*/},
  morestring=[b]',
  morestring=[b]",
}

% Esquema de color + apariencia común de todos los listados (colores en tfg_vars.tex).
\lstset{
  backgroundcolor=\color{codeBackground},
  basicstyle=\ttfamily\footnotesize,
  keywordstyle=\bfseries\color{codeKeyword},
  commentstyle=\itshape\color{codeComment},
  stringstyle=\color{codeString},
  numbers=left,
  numberstyle=\tiny\color{codeNumbers},
  numbersep=10pt,
  breaklines=true,
  showstringspaces=false,
  frame=Ltb,
  framerule=0pt,
  framesep=4pt,
  xleftmargin=\parindent,
  captionpos=b,
  tabsize=2,
}

% ---------------------------------------------------------------------
%  FUENTES DE LOS TÍTULOS Y FORMATO DE SECCIONES (titlesec)
% ---------------------------------------------------------------------
\newcommand{\dedicationfont}{\fontsize{14}{17.5}\selectfont}
\newcommand{\copyrightfont}{\fontsize{6}{7.5}\selectfont}
\newcommand{\sectionalfont}{\bfseries}
\newcommand{\chapternumberfont}{\sectionalfont\fontsize{64}{80}\selectfont}
\newcommand{\chaptertitlefont}{\sectionalfont\fontsize{32}{40}\selectfont}
\newcommand{\sectiontitlefont}{\sectionalfont\fontsize{18}{22.5}\selectfont}
\newcommand{\subsectiontitlefont}{\sectionalfont\fontsize{16}{20}\selectfont}
\newcommand{\subsubsectiontitlefont}{\sectionalfont\fontsize{14}{17.5}\selectfont}
\newcommand{\headertitlefont}{\sectionalfont\fontsize{12}{15}\selectfont}

\RequirePackage{titlesec}
\titleformat{\chapter}[display]{}{\chapternumberfont\flushright\thechapter}{0pt}{\chaptertitlefont\flushright}{}
\titleformat{\section}[block]{}{\sectiontitlefont\thesection}{1.5ex}{\sectiontitlefont}{}
\titleformat{\subsection}[block]{}{\subsectiontitlefont\thesubsection}{1.5ex}{\subsectiontitlefont}{}
\titleformat{\subsubsection}[block]{}{\subsubsectiontitlefont\thesubsubsection}{1.5ex}{\subsubsectiontitlefont}{}

% ---------------------------------------------------------------------
%  TABLAS Y RÓTULOS (captions)
